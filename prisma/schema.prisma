  creator        User?                   @relation("WarehousePurchaseCreator", fields: [createdBy], references: [id])
  updater        User?                   @relation("WarehousePurchaseUpdater", fields: [updatedBy], references: [id])
  user           User?                   @relation("UserPurchases", fields: [userId], references: [id])

  @@index([purchaseNumber])
  @@index([supplierId])
  @@index([purchaseStatus])
  @@index([paymentStatus])
  @@index([purchaseDate])
  @@index([isActive])
  @@index([userId])
  @@map("warehouse_purchases")
}

// ============================================================
// WAREHOUSE INVOICE MODELS
// ============================================================

model WarehouseInvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String   @map("invoice_id")
  productId   String?  @map("product_id")
  productName String   @map("product_name")
  sku         String?
  description String?
  quantity    Int
  unitPrice   Float    @map("unit_price")
  taxRate     Float    @default(0) @map("tax_rate")
  taxAmount   Float    @default(0) @map("tax_amount")
  discount    Float    @default(0)
  totalPrice  Float    @map("total_price")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  invoice WarehouseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product?         @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
  @@map("warehouse_invoice_items")
}

model WarehouseInvoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique @map("invoice_number")
  invoiceDate   DateTime @default(now()) @map("invoice_date")
  dueDate       DateTime @map("due_date")

  orderId        String? @map("order_id")
  orderNumber    String? @map("order_number")
  customerId     String? @map("customer_id")
  customerName   String  @map("customer_name")
  customerEmail  String? @map("customer_email")
  customerPhone  String? @map("customer_phone")
  billingAddress Json?   @map("billing_address")

  subtotal      Float
  taxTotal      Float @default(0) @map("tax_total")
  discountTotal Float @default(0) @map("discount_total")
  grandTotal    Float @map("grand_total")

  invoiceStatus String @default("Draft") @map("invoice_status")
  paymentStatus String @default("Unpaid") @map("payment_status")
  paidAmount    Float  @default(0) @map("paid_amount")
  outstanding   Float  @default(0)

  notes String?

  createdBy String  @map("created_by")
  updatedBy String? @map("updated_by")
  isActive  Boolean @default(true) @map("is_active")
  isDeleted Boolean @default(false) @map("is_deleted")

  userId String? @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  items                 WarehouseInvoiceItem[]
  order                 Order?                 @relation(fields: [orderId], references: [id])
  customer              Customer?              @relation(fields: [customerId], references: [id])
  creator               User?                  @relation("WarehouseInvoiceCreator", fields: [createdBy], references: [id])
  updater               User?                  @relation("WarehouseInvoiceUpdater", fields: [updatedBy], references: [id])
  taxLiabilityAccountId String?                @map("tax_liability_account_id")
  taxLiabilityAccount   ChartOfAccount?        @relation("TaxLiabilityAccount", fields: [taxLiabilityAccountId], references: [id])
  payments              PaymentReceived[]
  creditNotes           CreditNote[]
  user                  User?                  @relation("UserInvoices", fields: [userId], references: [id])

  @@index([invoiceNumber])
  @@index([orderId])
  @@index([customerId])
  @@index([invoiceStatus])
  @@index([paymentStatus])
  @@index([invoiceDate])
  @@index([isActive])
  @@index([userId])
  @@map("warehouse_invoices")
}

// ============================================================
// CHART OF ACCOUNTS MODEL
// ============================================================

model ChartOfAccount {
  id             String  @id @default(uuid())
  code           String
  name           String
  type           String
  parentAccount  String  @default("") @map("parent_account")
  openingBalance Float   @default(0) @map("opening_balance")
  currentBalance Float   @default(0) @map("current_balance")
  balanceType    String  @default("Debit") @map("balance_type")
  description    String  @default("")
  taxCode        String  @default("N/A") @map("tax_code")
  isActive       Boolean @default(true) @map("is_active")
  createdBy      String  @map("created_by")

  userId String? @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  creator              User?                @relation("ChartOfAccountCreator", fields: [createdBy], references: [id])
  user                 User?                @relation("UserChartOfAccounts", fields: [userId], references: [id])
  bankAccounts         BankAccount[]
  journalLines         JournalLine[]
  taxLiabilityInvoices WarehouseInvoice[]   @relation("TaxLiabilityAccount")
  expenses             Expense[]            @relation("ExpenseToAccount")
  incomes              Income[]             @relation("IncomeToAccount")
  accountsReceivable   AccountsReceivable[] @relation("ARAccount")
  salesRevenue         SalesInvoice[]       @relation("SalesRevenueAccount")
  arInvoices           SalesInvoice[]       @relation("ARAccount")
  inventoryAccounts    PurchaseInvoice[]    @relation("InventoryAccount")
  accountsPayable      AccountsPayable[]    @relation("APAccount")
  purchaseInvoices     PurchaseInvoice[]    @relation("APAccount")

  @@unique([code, userId])
  @@index([code])
  @@index([type])
  @@index([isActive])
  @@index([createdBy])
  @@index([userId])
  @@map("chart_of_accounts")
}

// ============================================================
// ACCOUNTS RECEIVABLE MODEL
// ============================================================

model AccountsReceivable {
  id            String @id @default(uuid())
  invoiceId     String @unique @map("invoice_id")
  invoiceNumber String @map("invoice_number")
  customerId    String @map("customer_id")
  customerName  String @map("customer_name")

  amount      Float
  paidAmount  Float    @default(0) @map("paid_amount")
  outstanding Float
  dueDate     DateTime @map("due_date")

  status String @default("Current") // Current, Overdue, Paid, WrittenOff

  notes String?

  accountId String? @map("account_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  invoice       SalesInvoice           @relation(fields: [invoiceId], references: [id])
  customer      Customer               @relation(fields: [customerId], references: [id])
  account       ChartOfAccount?        @relation("ARAccount", fields: [accountId], references: [id])
  payments      PaymentReceived[]
  salesPayments SalesPaymentReceived[]

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
