// prisma/schema.prisma - COMPLETE FINAL VERSION

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USER & AUTH MODELS
// ============================================================

model User {
  id        String  @id @default(uuid())
  firstName String  @map("first_name")
  lastName  String  @map("last_name")
  email     String  @unique
  password  String
  phone     String  @default("")
  country   String  @default("Pakistan")
  role      String  @default("user")
  isActive  Boolean @default(true) @map("is_active")

  resetOtp       String?   @map("reset_otp")
  resetOtpExpiry DateTime? @map("reset_otp_expiry")

  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockUntil           DateTime? @map("lock_until")
  requiresLoginOtp    Boolean   @default(false) @map("requires_login_otp")
  loginOtp            String?   @map("login_otp")
  loginOtpExpiry      DateTime? @map("login_otp_expiry")

  organizationName String @default("") @map("organization_name")
  address          String @default("")
  contactNo        String @default("") @map("contact_no")
  websiteLink      String @default("") @map("website_link")
  businessDetails  Json?  @default("{}") @map("business_details")

  subscriptionPlan      String    @default("none") @map("subscription_plan")
  subscriptionStatus    String    @default("active") @map("subscription_status")
  subscriptionStartDate DateTime? @map("subscription_start_date")
  subscriptionEndDate   DateTime? @map("subscription_end_date")
  trialStartDate        DateTime? @map("trial_start_date")
  trialEndDate          DateTime? @map("trial_end_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  subscriptions             Subscription[]
  createdProducts           Product[]           @relation("ProductCreator")
  updatedProducts           Product[]           @relation("ProductUpdater")
  createdCategories         Category[]          @relation("CategoryCreator")
  updatedCategories         Category[]          @relation("CategoryUpdater")
  createdSuppliers          Supplier[]          @relation("SupplierCreator")
  createdSettings           Setting[]           @relation("SettingCreator")
  updatedSettings           Setting[]           @relation("SettingUpdater")
  stockMovements            StockMovement[]     @relation("StockMovementCreator")
  orderCreators             Order[]             @relation("OrderCreator")
  orderUpdaters             Order[]             @relation("OrderUpdater")
  orderPickers              Order[]             @relation("OrderPicker")
  orderPackers              Order[]             @relation("OrderPacker")
  orderShippers             Order[]             @relation("OrderShipper")
  returnCreators            Return[]            @relation("ReturnCreator")
  returnUpdaters            Return[]            @relation("ReturnUpdater")
  returnApprovers           Return[]            @relation("ReturnApprover")
  returnCustomers           Return[]            @relation("ReturnCustomer")
  customerCreators          Customer[]          @relation("CustomerCreator")
  customerUpdaters          Customer[]          @relation("CustomerUpdater")
  refundCreators            Refund[]            @relation("RefundCreator")
  refundUpdaters            Refund[]            @relation("RefundUpdater")
  refundProcessors          Refund[]            @relation("RefundProcessor")
  refundCustomers           Refund[]            @relation("RefundCustomer")
  warehouseInvoiceCreators  WarehouseInvoice[]  @relation("WarehouseInvoiceCreator")
  warehouseInvoiceUpdaters  WarehouseInvoice[]  @relation("WarehouseInvoiceUpdater")
  warehousePurchaseCreators WarehousePurchase[] @relation("WarehousePurchaseCreator")
  warehousePurchaseUpdaters WarehousePurchase[] @relation("WarehousePurchaseUpdater")

  chartOfAccountCreators  ChartOfAccount[]  @relation("ChartOfAccountCreator")
  bankAccountCreators     BankAccount[]     @relation("BankAccountCreator")
  journalEntryCreators    JournalEntry[]    @relation("JournalEntryCreator")
  journalEntryPosters     JournalEntry[]    @relation("JournalEntryPoster")
  billCreators            Bill[]            @relation("BillCreator")
  incomeCreators          Income[]          @relation("IncomeCreator")
  incomePosters           Income[]          @relation("IncomePoster")
  expenseCreators         Expense[]         @relation("ExpenseCreator")
  expensePosters          Expense[]         @relation("ExpensePoster")
  creditNoteCreators      CreditNote[]      @relation("CreditNoteCreator")
  paymentReceivedCreators PaymentReceived[] @relation("PaymentReceivedCreator")
  paymentMadeCreators     PaymentMade[]     @relation("PaymentMadeCreator")
  fixedAssetCreators      FixedAsset[]      @relation("FixedAssetCreator")
  loanCreators            Loan[]            @relation("LoanCreator")

  userProducts             Product[]              @relation("UserProducts")
  userCategories           Category[]             @relation("UserCategories")
  userSuppliers            Supplier[]             @relation("UserSuppliers")
  userCustomers            Customer[]             @relation("UserCustomers")
  userOrders               Order[]                @relation("UserOrders")
  userReturns              Return[]               @relation("UserReturns")
  userRefunds              Refund[]               @relation("UserRefunds")
  userPurchases            WarehousePurchase[]    @relation("UserPurchases")
  userInvoices             WarehouseInvoice[]     @relation("UserInvoices")
  userStockMovements       StockMovement[]        @relation("UserStockMovements")
  userSettings             Setting[]              @relation("UserSettings")
  userChartOfAccounts      ChartOfAccount[]       @relation("UserChartOfAccounts")
  userBankAccounts         BankAccount[]          @relation("UserBankAccounts")
  userJournalEntries       JournalEntry[]         @relation("UserJournalEntries")
  userBills                Bill[]                 @relation("UserBills")
  userIncomes              Income[]               @relation("UserIncomes")
  userExpenses             Expense[]              @relation("UserExpenses")
  userPaymentsReceived     PaymentReceived[]      @relation("UserPaymentsReceived")
  userPaymentsMade         PaymentMade[]          @relation("UserPaymentsMade")
  userCreditNotes          CreditNote[]           @relation("UserCreditNotes")
  userFixedAssets          FixedAsset[]           @relation("UserFixedAssets")
  userLoans                Loan[]                 @relation("UserLoans")
  deliveryCreators         Delivery[]             @relation("DeliveryCreator")
  deliveryUpdaters         Delivery[]             @relation("DeliveryUpdater")
  deliveryConfirmers       Delivery[]             @relation("DeliveryConfirmer")
  userDeliveries           Delivery[]             @relation("UserDeliveries")
  quotationCreators        Quotation[]            @relation("QuotationCreator")
  quotationUpdaters        Quotation[]            @relation("QuotationUpdater")
  userQuotations           Quotation[]            @relation("UserQuotations")
  salesInvoiceCreators     SalesInvoice[]         @relation("SalesInvoiceCreator")
  salesInvoiceUpdaters     SalesInvoice[]         @relation("SalesInvoiceUpdater")
  userSalesInvoices        SalesInvoice[]         @relation("UserSalesInvoices")
  salesPaymentCreators     SalesPaymentReceived[] @relation("SalesPaymentCreator")
  salesPaymentUpdaters     SalesPaymentReceived[] @relation("SalesPaymentUpdater")
  userSalesPayments        SalesPaymentReceived[] @relation("UserSalesPayments")
  purchaseOrderCreators    PurchaseOrder[]        @relation("PurchaseOrderCreator")
  purchaseOrderUpdaters    PurchaseOrder[]        @relation("PurchaseOrderUpdater")
  userPurchaseOrders       PurchaseOrder[]        @relation("UserPurchaseOrders")
  goodsReceivingCreators   GoodsReceiving[]       @relation("GoodsReceivingCreator")
  goodsReceivingUpdaters   GoodsReceiving[]       @relation("GoodsReceivingUpdater")
  goodsReceivingConfirmers GoodsReceiving[]       @relation("GoodsReceivingConfirmer")
  userGoodsReceivings      GoodsReceiving[]       @relation("UserGoodsReceivings")
  purchaseInvoiceCreators  PurchaseInvoice[]      @relation("PurchaseInvoiceCreator")
  purchaseInvoiceUpdaters  PurchaseInvoice[]      @relation("PurchaseInvoiceUpdater")
  userPurchaseInvoices     PurchaseInvoice[]      @relation("UserPurchaseInvoices")

  purchasePaymentMakeCreators PurchasePaymentMake[] @relation("PurchasePaymentMakeCreator")
  purchasePaymentMakeUpdaters PurchasePaymentMake[] @relation("PurchasePaymentMakeUpdater")
  userPurchasePayments        PurchasePaymentMake[] @relation("UserPurchasePayments")

  purchaseReturnCreators   PurchaseReturn[] @relation("PurchaseReturnCreator")
  purchaseReturnUpdaters   PurchaseReturn[] @relation("PurchaseReturnUpdater")
  purchaseReturnProcessors PurchaseReturn[] @relation("PurchaseReturnProcessor")
  purchaseReturnCancellers PurchaseReturn[] @relation("PurchaseReturnCanceller")
  userPurchaseReturns      PurchaseReturn[] @relation("UserPurchaseReturns")

  transactionCreators Transaction[] @relation("TransactionCreator")
  transactionPosters  Transaction[] @relation("TransactionPoster")

  @@index([email])
  @@map("users")
}

model Subscription {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan           String
  status         String    @default("active")
  startDate      DateTime  @map("start_date")
  endDate        DateTime? @map("end_date")
  amount         Float
  currency       String    @default("PKR")
  paymentMethod  String    @map("payment_method")
  transactionId  String    @default("") @map("transaction_id")
  paymentDetails Json?     @map("payment_details")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

// ============================================================
// CUSTOMER MODEL
// ============================================================

model Customer {
  id             String @id @default(uuid())
  customerNumber String @unique @map("customer_number")

  name         String
  email        String? @unique
  phone        String?
  company      String?
  customerType String  @default("Individual") @map("customer_type")
  taxId        String? @map("tax_id")

  address         Json?
  shippingAddress Json? @map("shipping_address")
  billingAddress  Json? @map("billing_address")

  status String @default("Active")

  loyaltyPoints      Int       @default(0) @map("loyalty_points")
  totalOrders        Int       @default(0) @map("total_orders")
  totalSpent         Float     @default(0) @map("total_spent")
  averageOrderValue  Float     @default(0) @map("average_order_value")
  lastOrderDate      DateTime? @map("last_order_date")
  outstandingBalance Float     @default(0) @map("outstanding_balance")

  notes String?
  tags  String[] @default([])

  preferences Json?

  createdBy String  @map("created_by")
  updatedBy String? @map("updated_by")
  isActive  Boolean @default(true) @map("is_active")
  isDeleted Boolean @default(false) @map("is_deleted")

  userId String? @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  creator            User?                  @relation("CustomerCreator", fields: [createdBy], references: [id])
  updater            User?                  @relation("CustomerUpdater", fields: [updatedBy], references: [id])
  user               User?                  @relation("UserCustomers", fields: [userId], references: [id])
  orders             Order[]
  warehouseInvoices  WarehouseInvoice[]
  creditNotes        CreditNote[]
  payments           PaymentReceived[]
  incomes            Income[]
  deliveries         Delivery[]
  quotations         Quotation[]
  salesInvoices      SalesInvoice[]
  accountsReceivable AccountsReceivable[]
  salesPayments      SalesPaymentReceived[]
  transactions       Transaction[]          @relation("CustomerTransactions")

  @@index([customerNumber])
  @@index([email])
  @@index([phone])
  @@index([customerType])
  @@index([status])
  @@index([isActive])
  @@index([name])
  @@index([userId])
  @@map("customers")
}

// ============================================================
// PRODUCT MODEL
// ============================================================

model Product {
  id               String   @id @default(uuid())
  productId        String?  @unique @map("product_id")
  name             String
  sku              String
  barcodeNumber    String?  @unique @map("barcode_number")
  barcodeImage     String?  @map("barcode_image")
  description      String?
  shortDescription String?  @map("short_description")
  tags             String[] @default([])

  categoryId      String? @map("category_id")
  categoryName    String? @map("category_name")
  subCategoryId   String? @map("sub_category_id")
  subCategoryName String? @map("sub_category_name")
  brandId         String? @map("brand_id")
  brandName       String? @map("brand_name")
  modelNumber     String? @map("model_number")
  productType     String  @default("Physical") @map("product_type")
  hsCode          String? @map("hs_code")

  supplierId   String? @map("supplier_id")
  supplierName String? @map("supplier_name")
  supplierSku  String? @map("supplier_sku")
  leadTimeDays Int     @default(0) @map("lead_time_days")
  minOrderQty  Int     @default(1) @map("min_order_qty")
  maxOrderQty  Int     @default(999) @map("max_order_qty")
  reorderPoint Int     @default(10) @map("reorder_point")
  reorderQty   Int     @default(50) @map("reorder_qty")

  costPrice         Float     @map("cost_price")
  sellingPrice      Float     @map("selling_price")
  landingCost       Float     @default(0) @map("landing_cost")
  margin            Float     @default(0)
  marginPercentage  Float     @default(0) @map("margin_percentage")
  specialPrice      Float     @default(0) @map("special_price")
  specialPriceStart DateTime? @map("special_price_start")
  specialPriceEnd   DateTime? @map("special_price_end")
  taxRate           Float     @default(0) @map("tax_rate")
  taxType           String    @default("Exclusive") @map("tax_type")
  currencyCode      String    @default("PKR") @map("currency_code")
  totalValue        Float     @default(0) @map("total_value")
  retailPrice       Float     @default(0) @map("retail_price")
  wholesalePrice    Float     @default(0) @map("wholesale_price")

  currentStock     Int    @default(0) @map("current_stock")
  minimumStock     Int    @default(5) @map("minimum_stock")
  maximumStock     Int    @default(100) @map("maximum_stock")
  openingStock     Int    @default(0) @map("opening_stock")
  reservedStock    Int    @default(0) @map("reserved_stock")
  availableStock   Int    @default(0) @map("available_stock")
  reorderLevel     Int    @default(0) @map("reorder_level")
  safetyStock      Int    @default(0) @map("safety_stock")
  stockUnitName    String @default("Pcs") @map("stock_unit_name")
  conversionFactor Float  @default(1) @map("conversion_factor")

  isBoxBased  Boolean @default(false) @map("is_box_based")
  boxQuantity Int     @default(0) @map("box_quantity")
  boxUnitName String  @default("Box") @map("box_unit_name")

  rackLocationId       String? @map("rack_location_id")
  rackLocationName     String  @default("A-1-B1") @map("rack_location_name")
  zoneId               String? @map("zone_id")
  zoneName             String? @map("zone_name")
  palletNumber         String? @map("pallet_number")
  shelfNumber          String? @map("shelf_number")
  storageConditionName String  @default("Normal") @map("storage_condition_name")
  temperatureMin       Float?  @map("temperature_min")
  temperatureMax       Float?  @map("temperature_max")
  humidityMin          Float?  @map("humidity_min")
  humidityMax          Float?  @map("humidity_max")

  weight         Float    @default(0)
  weightUnitName String   @default("KG") @map("weight_unit_name")
  length         Float    @default(0)
  width          Float    @default(0)
  height         Float    @default(0)
  dimensionUnit  String   @default("cm") @map("dimension_unit")
  volume         Float    @default(0)
  color          String?
  colors         String[] @default([])
  size           String?
  sizes          String[] @default([])
  material       String?
  finish         String?

  hasExpiry         Boolean   @default(false) @map("has_expiry")
  isBatchManaged    Boolean   @default(false) @map("is_batch_managed")
  isSerialManaged   Boolean   @default(false) @map("is_serial_managed")
  isExpiryManaged   Boolean   @default(false) @map("is_expiry_managed")
  expiryDate        DateTime? @map("expiry_date")
  manufacturingDate DateTime? @map("manufacturing_date")
  batchNumber       String?   @map("batch_number")
  shelfLifeDays     Int       @default(0) @map("shelf_life_days")
  serialTracking    Boolean   @default(false) @map("serial_tracking")

  countryOfOriginName  String? @map("country_of_origin_name")
  shippingClass        String  @default("Normal") @map("shipping_class")
  handlingInstructions String? @map("handling_instructions")
  stackingLimit        Int     @default(0) @map("stacking_limit")
  freightClass         String? @map("freight_class")
  dangerousGoods       Boolean @default(false) @map("dangerous_goods")
  unNumber             String? @map("un_number")

  warrantyPeriod    Int     @default(0) @map("warranty_period")
  warrantyUnit      String  @default("Months") @map("warranty_unit")
  isReturnable      Boolean @default(true) @map("is_returnable")
  returnDays        Int     @default(7) @map("return_days")
  returnPolicy      String? @map("return_policy")
  replacementPolicy String? @map("replacement_policy")

  mainImage    String?  @map("main_image")
  images       String[] @default([])
  videoUrl     String?  @map("video_url")
  specSheet    String?  @map("spec_sheet")
  userManual   String?  @map("user_manual")
  certificates String[] @default([])

  isVariant         Boolean @default(false) @map("is_variant")
  parentProductId   String? @map("parent_product_id")
  variantType       String? @map("variant_type")
  variantAttributes Json?   @map("variant_attributes")

  isBulkManaged           Boolean @default(false) @map("is_bulk_managed")
  hasIndividualTracking   Boolean @default(false) @map("has_individual_tracking")
  defaultQuantityPerBatch Int     @default(0) @map("default_quantity_per_batch")
  bulkUnit                String  @default("Bale") @map("bulk_unit")

  status     String  @default("Active")
  visibility Boolean @default(true)
  featured   Boolean @default(false)
  newArrival Boolean @default(false) @map("new_arrival")
  bestSeller Boolean @default(false) @map("best_seller")
  onSale     Boolean @default(false) @map("on_sale")
  isActive   Boolean @default(true) @map("is_active")

  createdBy       String    @map("created_by")
  updatedBy       String?   @map("updated_by")
  lastCountedDate DateTime? @map("last_counted_date")
  lastCountedBy   String?   @map("last_counted_by")
  notes           String?

  attributes   Json?
  customFields Json? @map("custom_fields")

  userId String? @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  category             Category?               @relation(fields: [categoryId], references: [id])
  supplier             Supplier?               @relation(fields: [supplierId], references: [id])
  creator              User?                   @relation("ProductCreator", fields: [createdBy], references: [id])
  updater              User?                   @relation("ProductUpdater", fields: [updatedBy], references: [id])
  parentProduct        Product?                @relation("ProductVariants", fields: [parentProductId], references: [id])
  variants             Product[]               @relation("ProductVariants")
  stockMovements       StockMovement[]
  orderItems           OrderItem[]
  returnItems          ReturnItem[]
  purchaseItems        WarehousePurchaseItem[]
  invoiceItems         WarehouseInvoiceItem[]
  user                 User?                   @relation("UserProducts", fields: [userId], references: [id])
  deliveryItems        DeliveryItem[]
  quotationItems       QuotationItem[]
  salesInvoiceItems    SalesInvoiceItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  goodsReceivingItems  GoodsReceivingItem[]
  purchaseInvoiceItems PurchaseInvoiceItem[]
  purchaseReturnItems  PurchaseReturnItem[]

  @@unique([sku, userId])
  @@index([sku])
  @@index([productId])
  @@index([categoryId])
  @@index([supplierId])
  @@index([currentStock])
  @@index([isActive])
  @@index([status])
  @@index([barcodeNumber])
  @@index([userId])
  @@map("products")
}

// ============================================================
// CATEGORY MODEL
// ============================================================

model Category {
  id          String  @id @default(uuid())
  name        String
  slug        String?
  code        String?
  description String?

  parentId   String? @map("parent_id")
  parentName String? @map("parent_name")
  level      Int     @default(1)
  path       String? @default("")

  subCategoryCount Int @default(0) @map("sub_category_count")

  isActive  Boolean @default(true) @map("is_active")
  isDeleted Boolean @default(false) @map("is_deleted")

  createdBy String  @map("created_by")
  updatedBy String? @map("updated_by")

  userId String? @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  creator  User?      @relation("CategoryCreator", fields: [createdBy], references: [id])
  updater  User?      @relation("CategoryUpdater", fields: [updatedBy], references: [id])
  products Product[]
  user     User?      @relation("UserCategories", fields: [userId], references: [id])

  @@unique([name, userId])
  @@unique([code, userId])
  @@unique([slug, userId])
  @@index([parentId])
  @@index([level])
  @@index([slug])
  @@index([code])
  @@index([isActive])
  @@index([userId])
  @@map("categories")
}

// ============================================================
// SUPPLIER MODEL
// ============================================================

model Supplier {
  id            String  @id @default(uuid())
  name          String
  companyName   String? @map("company_name")
  code          String?
  contactPerson String? @map("contact_person")
  department    String?
  phone         String?
  email         String?
  address       String?
  city          String?
  country       String  @default("Pakistan")
  industry      String?
  businessType  String? @map("business_type")
  paymentTerms  String  @default("Net 30") @map("payment_terms")
  gstNumber     String? @map("gst_number")
  taxId         String? @map("tax_id")
  status        String  @default("active")
  isPreferred   Boolean @default(false) @map("is_preferred")
  isVerified    Boolean @default(false) @map("is_verified")
  createdBy     String  @map("created_by")
  notes         String?

  userId String? @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  creator          User?                 @relation("SupplierCreator", fields: [createdBy], references: [id])
  user             User?                 @relation("UserSuppliers", fields: [userId], references: [id])
  products         Product[]
  stockMovements   StockMovement[]
  purchases        WarehousePurchase[]
  bills            Bill[]
  Expense          Expense[]
  paymentsMade     PaymentMade[]
  fixedAssets      FixedAsset[]
  Loan             Loan[]
  refunds          Refund[]              @relation("SupplierRefunds")
  returns          Return[]              @relation("SupplierReturns")
  purchaseOrders   PurchaseOrder[]
  goodsReceivings  GoodsReceiving[]
  purchaseInvoices PurchaseInvoice[]
  accountsPayable  AccountsPayable[]
  purchasePayments PurchasePaymentMake[]
  purchaseReturns  PurchaseReturn[]
  transactions     Transaction[]         @relation("SupplierTransactions")

  @@unique([code, userId])
  @@unique([email, userId])
  @@unique([phone, userId])
  @@index([code])
  @@index([status])
  @@index([email])
  @@index([phone])
  @@index([createdAt])
  @@index([name])
  @@index([userId])
  @@map("suppliers")
}

// ============================================================
// SETTINGS MODEL
// ============================================================

model Setting {
  id           String  @id @default(uuid())
  category     String
  name         String
  metadata     Json?
  isDefault    Boolean @default(false) @map("is_default")
  displayOrder Int     @default(0) @map("display_order")
  isActive     Boolean @default(true) @map("is_active")
  createdBy    String  @map("created_by")
  updatedBy    String? @map("updated_by")

  userId String? @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  creator User? @relation("SettingCreator", fields: [createdBy], references: [id])
  updater User? @relation("SettingUpdater", fields: [updatedBy], references: [id])
  user    User? @relation("UserSettings", fields: [userId], references: [id])

  @@unique([category, name, userId])
  @@index([category])
  @@index([category, isDefault])
  @@index([isActive])
  @@index([userId])
  @@map("settings")
}

// ============================================================
// STOCK MOVEMENT MODEL
// ============================================================

model StockMovement {
  id            String @id @default(uuid())
  productId     String @map("product_id")
  productName   String @map("product_name")
  type          String
  quantity      Int
  previousStock Int    @map("previous_stock")
  newStock      Int    @map("new_stock")

  stockType    String @default("bulk") @map("stock_type")
  stockDetails Json?  @map("stock_details")

  reason       String
  supplierId   String? @map("supplier_id")
  supplierName String? @map("supplier_name")
  customerName String? @map("customer_name")
  reference    String?
  purchaseId   String? @map("purchase_id")
  status       String  @default("Completed")
  notes        String?

  createdBy String @map("created_by")

  userId String? @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  product  Product?           @relation(fields: [productId], references: [id])
  supplier Supplier?          @relation(fields: [supplierId], references: [id])
  purchase WarehousePurchase? @relation(fields: [purchaseId], references: [id])
  creator  User?              @relation("StockMovementCreator", fields: [createdBy], references: [id])
  user     User?              @relation("UserStockMovements", fields: [userId], references: [id])

  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@index([status])
  @@index([supplierId])
  @@index([purchaseId])
  @@index([userId])
  @@map("stock_movements")
}

// ============================================================
// ORDER MODELS
// ============================================================

model OrderItem {
  id           String  @id @default(uuid())
  orderId      String  @map("order_id")
  productId    String  @map("product_id")
  productName  String  @map("product_name")
  sku          String
  quantity     Int
  unitPrice    Float   @map("unit_price")
  totalPrice   Float   @map("total_price")
  weight       Float   @default(0)
  weightUnit   String  @default("KG") @map("weight_unit")
  dimensions   String?
  taxRate      Float   @default(0) @map("tax_rate")
  taxAmount    Float   @default(0) @map("tax_amount")
  discount     Float   @default(0)
  batchNumber  String? @map("batch_number")
  serialNumber String? @map("serial_number")
  notes        String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Order {
  id                   String    @id @default(uuid())
  orderNumber          String    @unique @map("order_number")
  orderDate            DateTime  @default(now()) @map("order_date")
  expectedDeliveryDate DateTime? @map("expected_delivery_date")

  customerId      String? @map("customer_id")
  customerName    String  @map("customer_name")
  customerEmail   String? @map("customer_email")
  customerPhone   String? @map("customer_phone")
  customerType    String  @default("Individual") @map("customer_type")
  customerCompany String? @map("customer_company")
  customerTaxId   String? @map("customer_tax_id")

  shippingAddress Json? @map("shipping_address")
  billingAddress  Json? @map("billing_address")

  subtotal      Float
  taxTotal      Float @default(0) @map("tax_total")
  shippingCost  Float @default(0) @map("shipping_cost")
  discountTotal Float @default(0) @map("discount_total")
  grandTotal    Float @map("grand_total")
  totalWeight   Float @default(0) @map("total_weight")
  totalItems    Int   @default(0) @map("total_items")

  paymentStatus    String    @default("Pending") @map("payment_status")
  paymentMethod    String    @default("Cash") @map("payment_method")
  paymentDate      DateTime? @map("payment_date")
  paymentReference String?   @map("payment_reference")

  orderStatus String @default("Pending") @map("order_status")

  orderType     String   @default("Standard") @map("order_type")
  priority      String   @default("Medium")
  source        String   @default("Web")
  salesPerson   String?  @map("sales_person")
  salesPersonId String?  @map("sales_person_id")
  tags          String[] @default([])

  shippingMethod  String    @default("Standard") @map("shipping_method")
  shippingCarrier String?   @map("shipping_carrier")
  trackingNumber  String?   @map("tracking_number")
  trackingUrl     String?   @map("tracking_url")
  shippingDate    DateTime? @map("shipping_date")
  deliveryDate    DateTime? @map("delivery_date")

  fulfillmentStatus    String  @default("Not Started") @map("fulfillment_status")
  pickedBy             String? @map("picked_by")
  packedBy             String? @map("packed_by")
  shippedBy            String? @map("shipped_by")
  pickListGenerated    Boolean @default(false) @map("pick_list_generated")
  packingSlipGenerated Boolean @default(false) @map("packing_slip_generated")

  couponCode     String? @map("coupon_code")
  couponDiscount Float   @default(0) @map("coupon_discount")

  customerNotes String? @map("customer_notes")
  internalNotes String? @map("internal_notes")
  orderNotes    Json?   @map("order_notes")

  approvalRequired Boolean   @default(false) @map("approval_required")
  approvedBy       String?   @map("approved_by")
  approvedAt       DateTime? @map("approved_at")
  approvalStatus   String    @default("Pending") @map("approval_status")

  attachments Json? @default("[]")

  createdBy String  @map("created_by")
  updatedBy String? @map("updated_by")
  isActive  Boolean @default(true) @map("is_active")
  isDeleted Boolean @default(false) @map("is_deleted")

  userId String? @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  items              OrderItem[]
  returns            Return[]           @relation("OrderReturns")
  refunds            Refund[]           @relation("OrderRefunds")
  warehouseInvoices  WarehouseInvoice[]
  customer           Customer?          @relation(fields: [customerId], references: [id])
  creator            User?              @relation("OrderCreator", fields: [createdBy], references: [id])
  updater            User?              @relation("OrderUpdater", fields: [updatedBy], references: [id])
  picker             User?              @relation("OrderPicker", fields: [pickedBy], references: [id])
  packer             User?              @relation("OrderPacker", fields: [packedBy], references: [id])
  shipper            User?              @relation("OrderShipper", fields: [shippedBy], references: [id])
  user               User?              @relation("UserOrders", fields: [userId], references: [id])
  deliveries         Delivery[]         @relation("SalesOrderDeliveries")
  convertedQuotation Quotation?         @relation("ConvertedQuotation")
  salesInvoices      SalesInvoice[]

  @@index([orderNumber])
  @@index([customerId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([orderDate])
  @@index([orderType])
  @@index([priority])
  @@index([isActive])
  @@index([userId])
  @@map("orders")
}

// ============================================================
// RETURN MODELS (Sales & Purchase Returns)
// ============================================================

model ReturnItem {
  id             String  @id @default(uuid())
  returnId       String  @map("return_id")
  productId      String  @map("product_id")
  productName    String  @map("product_name")
  sku            String
  quantity       Int
  unitPrice      Float   @map("unit_price")
  totalPrice     Float   @map("total_price")
  returnQuantity Int     @map("return_quantity")
  reason         String
  condition      String  @default("New")
  refundAmount   Float   @map("refund_amount")
  batchNumber    String? @map("batch_number")
  serialNumber   String? @map("serial_number")
  notes          String?

  restockQuantity        Int?    @default(0) @map("restock_quantity")
  restockStatus          String? @default("Pending") @map("restock_status")
  returnReasonDetail     String? @map("return_reason_detail")
  replacementProductId   String? @map("replacement_product_id")
  replacementProductName String? @map("replacement_product_name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  return  Return   @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([returnId])
  @@index([productId])
  @@map("return_items")
}

model Return {
  id           String   @id @default(uuid())
  returnNumber String   @unique @map("return_number")
  returnDate   DateTime @default(now()) @map("return_date")

  orderId     String @map("order_id")
  orderNumber String @map("order_number")

  customerId    String? @map("customer_id")
  customerName  String  @map("customer_name")
  customerEmail String? @map("customer_email")
  customerPhone String? @map("customer_phone")

  subtotal      Float
  refundAmount  Float @map("refund_amount")
  restockingFee Float @default(0) @map("restocking_fee")
  shippingCost  Float @default(0) @map("shipping_cost")
  totalRefund   Float @map("total_refund")

  returnStatus String @default("Pending") @map("return_status")
  returnType   String @default("Sales Return") @map("return_type")

  reason       String
  notes        String?
  returnMethod String  @default("Original Payment") @map("return_method")

  supplierId    String? @map("supplier_id")
  supplierName  String? @map("supplier_name")
  supplierEmail String? @map("supplier_email")
  supplierPhone String? @map("supplier_phone")

  purchaseId     String? @map("purchase_id")
  purchaseNumber String? @map("purchase_number")

  returnReasonCategory String? @map("return_reason_category")

  restockStatus      String?  @default("Pending") @map("restock_status")
  qualityCheckPassed Boolean? @map("quality_check_passed")
  qualityCheckNotes  String?  @map("quality_check_notes")

  trackingNumber  String?   @map("tracking_number")
  shippingCarrier String?   @map("shipping_carrier")
  returnLabel     String?   @map("return_label")
  receivedDate    DateTime? @map("received_date")

  approvedBy      String?   @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?   @map("rejection_reason")

  images      String[] @default([])
  attachments Json?    @default("[]")

  createdBy String  @map("created_by")
  updatedBy String? @map("updated_by")
  isActive  Boolean @default(true) @map("is_active")
  isDeleted Boolean @default(false) @map("is_deleted")

  userId String? @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  items    ReturnItem[]
  order    Order              @relation("OrderReturns", fields: [orderId], references: [id])
  customer User?              @relation("ReturnCustomer", fields: [customerId], references: [id])
  supplier Supplier?          @relation("SupplierReturns", fields: [supplierId], references: [id])
  creator  User?              @relation("ReturnCreator", fields: [createdBy], references: [id])
  updater  User?              @relation("ReturnUpdater", fields: [updatedBy], references: [id])
  approver User?              @relation("ReturnApprover", fields: [approvedBy], references: [id])
  user     User?              @relation("UserReturns", fields: [userId], references: [id])
  purchase WarehousePurchase? @relation("PurchaseReturns", fields: [purchaseId], references: [id])
  refunds  Refund[]           @relation("ReturnRefunds")

  @@index([returnNumber])
  @@index([orderId])
  @@index([purchaseId])
  @@index([customerId])
  @@index([supplierId])
  @@index([returnStatus])
  @@index([returnType])
  @@index([returnDate])
  @@index([isActive])
  @@index([userId])
  @@map("returns")
}

// ============================================================
// REFUND MODELS (Sales & Purchase Refunds)
// ============================================================

model Refund {
  id           String   @id @default(uuid())
  refundNumber String   @unique @map("refund_number")
  refundDate   DateTime @default(now()) @map("refund_date")

  orderId     String? @map("order_id")
  orderNumber String? @map("order_number")

  customerId    String? @map("customer_id")
  customerName  String? @map("customer_name")
  customerEmail String? @map("customer_email")
  customerPhone String? @map("customer_phone")

  purchaseId     String? @map("purchase_id")
  purchaseNumber String? @map("purchase_number")

  supplierId    String? @map("supplier_id")
  supplierName  String? @map("supplier_name")
  supplierEmail String? @map("supplier_email")
  supplierPhone String? @map("supplier_phone")

  returnId     String? @map("return_id")
  returnNumber String? @map("return_number")

  amount       Float
  refundStatus String @default("Pending") @map("refund_status")
  refundMethod String @default("Original Payment") @map("refund_method")
  refundType   String @default("Sales Refund") @map("refund_type")

  reason          String
  notes           String?
  referenceNumber String? @map("reference_number")

  bankName          String? @map("bank_name")
  accountNumber     String? @map("account_number")
  accountHolderName String? @map("account_holder_name")

  processedBy   String?   @map("processed_by")
  processedAt   DateTime? @map("processed_at")
  completedAt   DateTime? @map("completed_at")
  failureReason String?   @map("failure_reason")

  attachments Json? @default("[]")

  createdBy String  @map("created_by")
  updatedBy String? @map("updated_by")
  isActive  Boolean @default(true) @map("is_active")
  isDeleted Boolean @default(false) @map("is_deleted")

  userId String? @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  order     Order?             @relation("OrderRefunds", fields: [orderId], references: [id])
  customer  User?              @relation("RefundCustomer", fields: [customerId], references: [id])
  purchase  WarehousePurchase? @relation("PurchaseRefunds", fields: [purchaseId], references: [id])
  supplier  Supplier?          @relation("SupplierRefunds", fields: [supplierId], references: [id])
  creator   User?              @relation("RefundCreator", fields: [createdBy], references: [id])
  updater   User?              @relation("RefundUpdater", fields: [updatedBy], references: [id])
  processor User?              @relation("RefundProcessor", fields: [processedBy], references: [id])
  user      User?              @relation("UserRefunds", fields: [userId], references: [id])
  return    Return?            @relation("ReturnRefunds", fields: [returnId], references: [id])

  @@index([refundNumber])
  @@index([orderId])
  @@index([purchaseId])
  @@index([customerId])
  @@index([supplierId])
  @@index([refundStatus])
  @@index([refundMethod])
  @@index([refundType])
  @@index([refundDate])
  @@index([isActive])
  @@index([userId])
  @@map("refunds")
}

// ============================================================
// WAREHOUSE PURCHASE MODELS
// ============================================================

model WarehousePurchaseItem {
  id          String   @id @default(uuid())
  purchaseId  String   @map("purchase_id")
  productId   String   @map("product_id")
  productName String   @map("product_name")
  sku         String
  quantity    Int
  receivedQty Int      @default(0) @map("received_qty")
  unitCost    Float    @map("unit_cost")
