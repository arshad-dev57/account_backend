}

// ============================================================
// ACCOUNTS PAYABLE MODEL
// ============================================================

model AccountsPayable {
  id            String @id @default(uuid())
  invoiceId     String @unique @map("invoice_id")
  invoiceNumber String @map("invoice_number")
  supplierId    String @map("supplier_id")
  supplierName  String @map("supplier_name")

  amount      Float
  paidAmount  Float    @default(0) @map("paid_amount")
  outstanding Float
  dueDate     DateTime @map("due_date")

  status String @default("Current") // Current, Overdue, Paid, WrittenOff

  notes String?

  accountId String? @map("account_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  invoice          PurchaseInvoice       @relation(fields: [invoiceId], references: [id])
  supplier         Supplier              @relation(fields: [supplierId], references: [id])
  account          ChartOfAccount?       @relation("APAccount", fields: [accountId], references: [id])
  payments         PaymentMade[]
  purchasePayments PurchasePaymentMake[] @relation("PaymentMakeAPRecords")
  PurchaseReturn   PurchaseReturn[]

  @@index([supplierId])
  @@index([status])
  @@index([dueDate])
  @@map("accounts_payable")
}

// ============================================================
// SALES PAYMENT RECEIVED MODELS
// ============================================================

model SalesPaymentReceived {
  id            String   @id @default(uuid())
  paymentNumber String   @unique @map("payment_number")
  paymentDate   DateTime @default(now()) @map("payment_date")
  customerId    String   @map("customer_id")
  customerName  String   @map("customer_name")
  amount        Float
  paymentMethod String   @map("payment_method") // Cash, Bank Transfer, Cheque, Credit Card
  reference     String?  @default("")

  bankAccountId   String? @map("bank_account_id")
  bankAccountName String? @default("") @map("bank_account_name")

  notes  String? @default("")
  status String  @default("Completed") // Pending, Completed, Failed, Cancelled

  createdBy String  @map("created_by")
  updatedBy String? @map("updated_by")
  isActive  Boolean @default(true) @map("is_active")
  isDeleted Boolean @default(false) @map("is_deleted")

  userId String? @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  customer        Customer              @relation(fields: [customerId], references: [id])
  bankAccount     BankAccount?          @relation(fields: [bankAccountId], references: [id])
  creator         User?                 @relation("SalesPaymentCreator", fields: [createdBy], references: [id])
  updater         User?                 @relation("SalesPaymentUpdater", fields: [updatedBy], references: [id])
  user            User?                 @relation("UserSalesPayments", fields: [userId], references: [id])
  invoicePayments SalesInvoicePayment[]
  journalEntry    JournalEntry?         @relation(fields: [journalEntryId], references: [id])
  journalEntryId  String?               @unique @map("journal_entry_id")
  arRecord        AccountsReceivable?   @relation(fields: [arRecordId], references: [id])
  arRecordId      String?               @map("ar_record_id")

  @@index([paymentNumber])
  @@index([customerId])
  @@index([paymentDate])
  @@index([status])
  @@index([isActive])
  @@index([userId])
  @@map("sales_payments_received")
}

