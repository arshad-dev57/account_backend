  user            User?                @relation("UserPurchaseReturns", fields: [userId], references: [id])
  journalEntry    JournalEntry?        @relation("PurchaseReturnJournalEntry", fields: [journalEntryId], references: [id])
  apRecord        AccountsPayable?     @relation(fields: [apRecordId], references: [id])

