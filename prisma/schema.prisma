  amount            Float
  category          String
  paymentMethod     String   @default("Cash")
  reference         String   @default("")

  customerId    String? @map("customer_id")
  customerName  String  @default("")
  vendorId      String? @map("vendor_id")
  vendorName    String  @default("")
  bankAccountId String? @map("bank_account_id")

  status String @default("Posted")

  createdBy String    @map("created_by")
  postedBy  String?   @map("posted_by")
  postedAt  DateTime? @map("posted_at")

  isActive  Boolean @default(true) @map("is_active")
  isDeleted Boolean @default(false) @map("is_deleted")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  customer       Customer?     @relation("CustomerTransactions", fields: [customerId], references: [id])
  vendor         Supplier?     @relation("SupplierTransactions", fields: [vendorId], references: [id])
  bankAccount    BankAccount?  @relation("BankAccountTransactions", fields: [bankAccountId], references: [id])
  creator        User?         @relation("TransactionCreator", fields: [createdBy], references: [id])
  poster         User?         @relation("TransactionPoster", fields: [postedBy], references: [id])
  journalEntry   JournalEntry? @relation("TransactionJournalEntry", fields: [journalEntryId], references: [id])
  journalEntryId String?       @unique @map("journal_entry_id")

  @@index([transactionNumber])
  @@index([type])
  @@index([category])
  @@index([date])
  @@index([status])
  @@index([customerId])
  @@index([vendorId])
  @@index([bankAccountId])
  @@index([createdBy])
  @@index([isActive])
  @@map("transactions")
}
